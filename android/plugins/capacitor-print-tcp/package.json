{
  "name": "capacitor-print-tcp",
  "version": "1.0.0",
  "description": "Capacitor plugin to send raw bytes to thermal printers via TCP (port 9100) and discover printers on LAN",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android",
    "dist"
  ],
  "capacitor": {
    "android": {
      "src": "android"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "typescript": "~5.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^6.0.0 || ^7.0.0 || ^8.0.0"
  }
}
