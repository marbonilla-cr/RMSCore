modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Preview RMS Wrapper"

[[workflows.workflow]]
name = "Preview RMS Wrapper"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx serve www -l 5000 --no-clipboard"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
