# =============================================================================
# RMS Mobile Wrapper - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT:
# - PROD URLs MUST use https:// (http is blocked for security)
# - DEV URLs can use http:// for local development
# - Frontend and backend should be on the same domain to avoid SameSite cookie issues
# =============================================================================

# Development URL (your local or staging RMS instance)
# Example: http://192.168.1.100:3000 or https://dev.yourcompany.com
BASE_URL_DEV=http://localhost:3000

# Production URL (your production RMS instance)
# MUST be https:// - the app will block non-HTTPS production URLs
BASE_URL_PROD=https://rms.yourcompany.com
